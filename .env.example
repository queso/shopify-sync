# Required — Shopify store credentials
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Required — Resend email settings
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=digest@yourdomain.com
RESEND_TO_EMAIL=you@yourdomain.com

# Optional — server and scheduling
PORT=3000
POLL_CRON=0 */4 * * *
DIGEST_CRON=0 7 * * *
DATABASE_PATH=./data/shopify-sync.db
